APP_HOSTNAME=modelo-backend
NODE_ENV=development
APP_VERSION=1.0.0
HTTP_PORT=3000

ACCESS_TOKEN_SECRET=modelo-back-end-access
ACCESS_TOKEN_EXPIRATION=86400s
